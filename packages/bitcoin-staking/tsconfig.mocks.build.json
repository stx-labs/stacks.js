{
  "extends": "../../tsconfig.build.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist/mocks",
    "rootDir": "./mocks",
    "resolveJsonModule": true,
    "tsBuildInfoFile": "./tsconfig.mocks.build.tsbuildinfo",
    "composite": true
  },
  "references": [
    {
      "path": "./tsconfig.build.json"
    }
  ],
  "include": ["mocks/**/*.ts", "mocks/**/*.json"],
  "exclude": ["mocks/generate.ts"]
}
