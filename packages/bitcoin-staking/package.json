{
  "name": "@stacks/bitcoin-staking",
  "version": "0.0.1",
  "description": "Library for Bitcoin Staking.",
  "license": "MIT",
  "author": "Hiro Systems PBC (https://hiro.so)",
  "homepage": "https://hiro.so/stacks-js",
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -b tsconfig.build.json",
    "build:esm": "tsc -p tsconfig.build.json --module ES6 --outDir ./dist/esm",
    "clean": "rimraf dist && tsc -b tsconfig.build.json --clean",
    "pack": "npm pack",
    "prepublishOnly": "npm run test && NODE_ENV=production npm run build",
    "start": "tsc -b tsconfig.build.json --watch --verbose",
    "test": "jest",
    "test:watch": "jest --watch --coverage=false",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "npm run typecheck -- --watch"
  },
  "dependencies": {
    "@noble/hashes": "1.1.5",
    "@scure/base": "1.1.1",
    "@scure/btc-signer": "^2.0.1",
    "@stacks/common": "^7.3.1",
    "@stacks/encryption": "^7.4.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@stacks/internal": "file:../internal",
    "rimraf": "^3.0.2"
  },
  "sideEffects": false,
  "typings": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "files": [
    "dist",
    "src"
  ],
  "keywords": [
    "Bitcoin",
    "Staking",
    "Stacks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/stacks.js.git"
  }
}
