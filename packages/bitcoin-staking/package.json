{
  "name": "@stacks/bitcoin-staking",
  "version": "0.0.1",
  "description": "Library for Bitcoin Staking.",
  "license": "MIT",
  "author": "Hiro Systems PBC (https://hiro.so)",
  "homepage": "https://hiro.so/stacks-js",
  "scripts": {
    "build": "npm run clean && npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -b tsconfig.build.json && npm run build:mocks-cjs",
    "build:esm": "tsc -p tsconfig.build.json --module ES6 --outDir ./dist/esm && npm run build:mocks-esm && npm run build:mocks-data",
    "build:mocks-cjs": "tsc -b tsconfig.mocks.build.json",
    "build:mocks-esm": "tsc -p tsconfig.mocks.build.json --module ES6 --outDir ./dist/esm-mocks",
    "build:mocks-data": "node -e \"const fs=require('fs');fs.cpSync('mocks/data','dist/mocks/data',{recursive:true});fs.cpSync('mocks/data','dist/esm-mocks/data',{recursive:true});\"",
    "clean": "rimraf dist && tsc -b tsconfig.build.json --clean && tsc -b tsconfig.mocks.build.json --clean",
    "pack": "npm pack",
    "prepublishOnly": "npm run test && NODE_ENV=production npm run build",
    "start": "tsc -b tsconfig.build.json --watch --verbose",
    "test": "jest",
    "test:watch": "jest --watch --coverage=false",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "npm run typecheck -- --watch",
    "generate-mocks": "TS_NODE_COMPILER_OPTIONS='{\"module\":\"commonjs\",\"moduleResolution\":\"node\",\"target\":\"ES2020\",\"esModuleInterop\":true}' ts-node --transpile-only --skip-project mocks/generate.ts"
  },
  "dependencies": {
    "@noble/hashes": "~2.0.0",
    "@scure/base": "~2.0.0",
    "@scure/btc-signer": "^2.0.1",
    "@stacks/common": "^7.3.1",
    "@stacks/encryption": "^7.4.0",
    "@stacks/network": "^7.3.1",
    "@stacks/transactions": "^7.4.0"
  },
  "devDependencies": {
    "@stacks/internal": "file:../internal",
    "rimraf": "^3.0.2"
  },
  "sideEffects": false,
  "typings": "dist/index.d.ts",
  "main": "dist/index.js",
  "module": "dist/esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/index.js"
    },
    "./mocks": {
      "types": "./dist/mocks/index.d.ts",
      "import": "./dist/esm-mocks/index.js",
      "require": "./dist/mocks/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "mocks"
  ],
  "keywords": [
    "Bitcoin",
    "Staking",
    "Stacks"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/stacks.js.git"
  }
}
