{
  "private": true,
  "name": "root",
  "workspaces": [
    "packages/**"
  ],
  "license": "MIT",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:docs": "rimraf docs && typedoc",
    "clean": "npm run clean --workspaces --if-present",
    "lint": "npm run lint:check && npm run fmt:check",
    "lint:check": "oxlint packages/**/src/",
    "lint:fix": "oxlint --fix packages/**/src/",
    "fmt": "oxfmt packages/**/src/",
    "fmt:check": "oxfmt --check packages/**/src/",
    "fix": "npm run lint:fix && npm run fmt",
    "madge": "madge --circular --extensions ts --exclude 'd.ts' packages/",
    "pack": "npm run pack --workspaces --if-present",
    "release": "npm run build && changeset publish",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "version": "changeset version && node .github/scripts/update-root-changelog.mjs",
    "prepare": "husky install .github/.husky"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.26.2",
    "@commitlint/cli": "^17.7.1",
    "@commitlint/config-conventional": "^17.7.0",
    "@types/bs58check": "^2.1.0",
    "@types/jest": "^29.5.3",
    "assert": "^2.0.0",
    "esbuild": "^0.19.0",
    "esbuild-loader": "^4.0.0",
    "husky": "^8.0.3",
    "inspectpack": "^4.7.1",
    "jest": "^29.6.2",
    "jest-fetch-mock": "^3.0.3",
    "jest-module-name-mapper": "^0.1.5",
    "madge": "^6.1.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "path-browserify": "^1.0.1",
    "rimraf": "^5.0.1",
    "stream-http": "^3.2.0",
    "ts-jest": "^29.1.1",
    "typedoc": "^0.28.18",
    "typescript": "^5.9.3",
    "webpack": "^5.88.2",
    "webpack-bundle-analyzer": "^4.9.0",
    "webpack-cli": "^5.1.4"
  },
  "overrides": {
    "blockstack": {
      "ajv": "6.12.6",
      "tough-cookie": "4.1.3"
    },
    "json5": "2.2.3",
    "nth-check": "2.0.1",
    "schema-inspector": "2.0.2",
    "socket.io-client": "4.5.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stx-labs/stacks.js.git"
  }
}
